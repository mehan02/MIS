# Use the backend URL that the .NET dev server actually listens on (see launchSettings)
# (Avoid redirecting from HTTP -> HTTPS to keep custom headers like X-EPF-NO intact.)
VITE_API_BASE_URL=http://127.0.0.1:5242

# Use this dev user for local development (auto-injected into requests)
VITE_DEV_EPF=ADM
VITE_DEV_USER_NAME=Admin

# Optional: force a specific role (USER / ADMIN / SUPER_ADMIN)
VITE_DEV_USER_ROLE=ADMIN
